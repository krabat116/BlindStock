generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum StockType {
  COUNT
  LENGTH
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id               Int           @id @default(autoincrement())
  name             String

  stockType        StockType     @default(COUNT)

  // COUNT type
  quantity         Int?
  minimumStock     Int?
  unit             String?

  // LENGTH type
  defaultLengthMm  Int?
  totalLengthMm    Int?
  minimumLengthMm  Int?
  cutoffLengthMm   Int?  // 막대 하나당 사용 불가 끝부분 길이(mm), 기본값 800

  categoryId       Int
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  transactions     Transaction[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([name, categoryId])
}

model Transaction {
  id             Int      @id @default(autoincrement())
  itemId         Int
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type           String

  // COUNT transaction
  quantity       Int?

  // LENGTH transaction
  lengthMm       Int?

  source         String?
  note           String?
  createdAt      DateTime @default(now())
}

// Customer page related

model Customer {
  id          String   @id @default(cuid())
  accountName String   @unique
  name        String?
  phone       String?
  email       String?
  companyName String?
  address     String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      CustomerOrder[]

  @@index([accountName])
  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([companyName])
}

model CustomerOrder {
  id           String      @id @default(cuid())
  customerId   String
  orderYear    Int
  orderMonth   Int
  orderSheetNo Int
  totalItems   Int         @default(0)
  fileName     String?
  fileHash     String?
  status       OrderStatus @default(PENDING)
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@index([customerId])
  @@index([orderYear, orderMonth])
  @@unique([orderYear, orderSheetNo])
}

model OrderItem {
  id              String   @id @default(cuid())
  customerOrderId String
  itemType        String
  itemName        String
  quantity        Int
  unit            String?
  createdAt       DateTime @default(now())

  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

// Auth

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  STAFF
}