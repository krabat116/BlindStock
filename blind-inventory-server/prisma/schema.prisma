generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id           Int           @id @default(autoincrement())
  name         String
  quantity     Int
  minimumStock Int
  unit         String
  categoryId   Int
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, categoryId])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  itemId    Int
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String
  quantity  Int
  source    String?
  note      String?
  createdAt DateTime @default(now())
}

// Customer page related

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  companyName String?
  address     String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      CustomerOrder[]

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([companyName])
}

model CustomerOrder {
  id          String      @id @default(cuid())
  customerId  String
  orderDate   DateTime    @default(now())
  fileName    String?
  orderNumber String?
  status      OrderStatus @default(PENDING)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([customerId])
  @@index([orderDate])
}

model OrderItem {
  id              String   @id @default(cuid())
  customerOrderId String
  itemType        String
  itemName        String
  quantity        Int
  unit            String?
  createdAt       DateTime @default(now())

  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}